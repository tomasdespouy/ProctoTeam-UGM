/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment files (IMPORTANT: Contains sensitive API keys)
.env*
!.env.example

# Firebase
firebase-debug.log*
firestore-debug.log*
ui-debug.log*
database-debug.log*
pubsub-debug.log*
storage-debug.log*
functions-debug.log*

# IDEs and editors
.vscode/
.idea/
*.swp
*.swo
*~

# Replit specific files
.idx/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
logs
*.log

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output

# Dependency directories
node_modules/
jspm_packages/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# Next.js build output
.next
out

# Nuxt.js build / generate output
.nuxt
dist

# Gatsby files
.cache/
# public (comentado porque Next.js necesita el directorio public)

# Storybook build outputs
.out
.storybook-out

# Temporary folders
tmp/
temp/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Firebase
.firebase/
.firebaserc

# Vercel
.vercel

# TensorFlow.js models (si se generan localmente)
/public/models/

# Archivos temporales de desarrollo
.modified
*.tmp

# Archivos de depuración y logs específicos del proyecto
*.debug.log
debug.log

# Service account keys y archivos sensibles
service-account-key.json
private-key*.json
*-key.json
*.key
*.pem

# Attached assets temporales (archivos de desarrollo)
attached_assets/

# Archivos de configuración local específicos del usuario
.replit
replit.nix

# Archivos de compilación TypeScript
next-env.d.ts

# Genkit local dev runtime state (traces/logs/servers, machine-specific)
.genkit/

# Generated documentation deliverables (regenerar desde scripts/, fuera de git)
# El informe PDF es de seguridad: no publicar en repos compartidos.
/*.docx
/*.pdf
/manuales/*.pptx
